# Use a stable Node.js LTS image
FROM node:20-alpine

# Set the working directory
WORKDIR /app

# Copy package files first to leverage Docker cache for installs
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy all frontend files (including jsconfig.json, components.json, and src)
COPY . .

# Expose the default Vite port
EXPOSE 5173

# Start Vite with --host to allow access from the Docker network
CMD ["npm", "run", "dev", "--", "--host"]

